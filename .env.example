# =============================================
# NEURALMARKET ENVIRONMENT CONFIGURATION
# =============================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control!

# ============ FRONTEND (PUBLIC) ============
# These values are exposed to the browser

# Supabase (Database & Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solana Network
NEXT_PUBLIC_SOLANA_PROGRAM_ID=A7FnyNVtkcRMEkhaBjgtKZ1Z7Mh4N9XLBN8AGneXNK2F
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# RPC Endpoint (Recommended: Use Helius for production)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_HELIUS_RPC=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Protocol Treasury (receives 0.05 SOL protocol fees)
NEXT_PUBLIC_TREASURY_WALLET=4yQBV4yJgxN8b1qLJ5V5X5gH9HbNjJBvLXK9HNKJ4KDj

# ============ SERVER-SIDE (PRIVATE) ============
# These values are NEVER exposed to the browser

# Supabase Service Key (Full database access - SERVER ONLY)
SUPABASE_SERVICE_KEY=your-service-role-key

# Kalshi API (Prediction Markets)
KALSHI_API_KEY_ID=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY=your-kalshi-private-key-base64
KALSHI_BUILDER_CODE=ORACULO_V2

# DFlow API (Liquidity & Order Routing)
DFLOW_API_KEY=your-dflow-api-key
DFLOW_API_SECRET=your-dflow-secret

# AI Services
OPENAI_API_KEY=your-openai-key

# ============ OBSERVABILITY (OPTIONAL) ============

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# PostHog (Analytics) - Optional
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============ DEVELOPMENT ============
# NODE_ENV is set automatically by Next.js
# Use this for local testing:
# NODE_ENV=development
